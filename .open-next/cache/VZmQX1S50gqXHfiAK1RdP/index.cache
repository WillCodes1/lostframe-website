url=%2Frevolv-logo.png&amp;w=128&amp;q=75 1x, /_next/image?url=%2Frevolv-logo.png&amp;w=256&amp;q=75 2x\" src=\"/_next/image?url=%2Frevolv-logo.png&amp;w=256&amp;q=75\"/></div></div></div></section><section id=\"ai-demo\" class=\"py-20 scroll-mt-24 bg-gradient-to-b from-white via-muted/20 to-white\"><div class=\"max-w-6xl mx-auto px-6\"><div class=\"transition-all duration-700 ease-out opacity-0 translate-y-8 \" style=\"transition-delay:0ms\"><div class=\"text-center mb-10\"><h2 class=\"text-4xl md:text-6xl font-bold mb-4 text-foreground\">See What We&#x27;d Build <span class=\"gold-shimmer-text\">For You</span></h2><p class=\"text-muted-foreground max-w-2xl mx-auto leading-relaxed\">This isn&#x27;t a chatbot demo. This is a glimpse of how our AI pipeline works—scanning your industry, identifying automation opportunities, and generating a full venture blueprint in seconds. This is what we do for every client engagement.</p></div></div><div class=\"transition-all duration-700 ease-out opacity-0 scale-95 \" style=\"transition-delay:0ms\"><div class=\"max-w-2xl mx-auto text-center\"><div class=\"relative mb-4\"><input type=\"text\" placeholder=\"Enter your industry (e.g. real estate, healthcare, defense, pool services...)\" class=\"w-full px-5 py-4 rounded-xl border-2 border-border bg-white text-foreground text-base placeholder:text-muted-foreground/40 focus:outline-none focus:ring-2 focus:ring-gold/40 focus:border-gold transition-all shadow-sm\" value=\"\"/><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-sparkles absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gold/30\" aria-hidden=\"true\"><path d=\"M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z\"></path><path d=\"M20 2v4\"></path><path d=\"M22 4h-4\"></path><circle cx=\"4\" cy=\"20\" r=\"2\"></circle></svg></div><button disabled=\"\" class=\"magnetic-btn glass-btn animate-pulse-glow inline-flex items-center gap-2 bg-transparent backdrop-blur-md text-foreground border border-foreground/30 px-8 py-3.5 rounded-xl text-base font-semibold disabled:opacity-40 disabled:cursor-not-allowed transition-all duration-300 hover:scale-105\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-rocket w-4 h-4\" aria-hidden=\"true\"><path d=\"M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5\"></path><path d=\"M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09\"></path><path d=\"M9 12a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.4 22.4 0 0 1-4 2z\"></path><path d=\"M9 12H4s.55-3.03 2-4c1.62-1.08 5 .05 5 .05\"></path></svg>Analyze My Industry</button><p class=\"text-xs text-muted-foreground/60 mt-3\">Free instant analysis — no email required</p></div></div></div></section><section class=\"py-20 bg-muted/30\"><div class=\"max-w-7xl mx-auto px-6\"><div class=\"transition-all duration-700 ease-out opacity-0 translate-y-8 \" style=\"transition-delay:0ms\"><div class=\"text-center mb-12\"><h2 class=\"text-4xl md:text-5xl font-bold mb-4\"><span class=\"gold-shimmer-text\">What We Architect</span></h2><p class=\"text-muted-foreground max-w-2xl mx-auto\">From intelligent startups to enterprise-scale solutions, we partner with visionaries to architect the next generation of AI-native ventures and mission-critical systems.</p></div></div><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6\"><div class=\"transition-all duration-700 ease-out opacity-0 translate-y-8 \" style=\"transition-delay:0ms\"><div class=\"tilt-card group bg-white rounded-2xl border border-border p-6 hover:shadow-lg hover:shadow-gold/5 hover:border-gold/20 transition-all duration-300 h-full\"><div class=\"flex items-center gap-3 mb-4\"><div class=\"p-2 rounded-lg bg-muted group-hover:bg-gold/10 transition-colors duration-300\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-building2 lucide-building-2 w-5 h-5 text-muted-foreground group-hover:text-gold transition-colors duration-300\" aria-hidden=\"true\"><path d=\"M10 12h4\"></path><path d=\"M10 8h4\"></path><path d=\"M14 21v-3a2 2 0 0 0-4 0v3\"></path><path d=\"M6 10H4a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2\"></path><path d=\"M6 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16\"></path></svg></div><h3 class=\"font-semibold text-foreground text-sm leading-tight\">Intelligent Enterprise Architecture</h3></div><p class=\"text-sm text-muted-foreground mb-5 leading-relaxed\">We architect intelligent enterprises from concept to deployment, providing technical expertise and strategic guidance.</p><div class=\"flex flex-wrap gap-2\"><span class=\"text-xs px-3 py-1 rounded-full border border-border text-muted-foreground hover:border-gold/30 hover:text-foreground hover:bg-gold/5 transition-all duration-200 cursor-default\">Partnership</span><span class=\"text-xs px-3 py-1 rounded-full border border-border text-muted-foreground hover:border-gold/30 hover:text-foreground hover:bg-gold/5 transition-all duration-200 cursor-default\">Strategy</span><span class=\"text-xs px-3 py-1 rounded-full border border-border text-muted-foreground hover:border-gold/30 hover:text-foreground hover:bg-gold/5 transition-all duration-200 cursor-default\">Technical Leadership</span></div></div></div><div class=\"transition-all duration-700 ease-out opacity-0 translate-y-8 \" style=\"transition-delay:100ms\"><div class=\"tilt-card group bg-white rounded-2xl border border-border p-6 hover:shadow-lg hover:shadow-gold/5 hover:border-gold/20 transition-all duration-300 h-full\"><div class=\"flex items-center gap-3 mb-4\"><div class=\"p-2 rounded-lg bg-muted group-hover:bg-gold/10 transition-colors duration-300\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-rocket w-5 h-5 text-muted-foreground group-hover:text-gold transition-colors duration-300\" aria-hidden=\"true\"><path d=\"M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5\"></path><path d=\"M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09\"></path><path d=\"M9 12a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.4 22.4 0 0 1-4 2z\"></path><path d=\"M9 12H4s.55-3.03 2-4c1.62-1.08 5 .05 5 .05\"></path></svg></div><h3 class=\"font-semibold text-foreground text-sm leading-tight\">Mission-Critical Product Engineering</h3></div><p class=\"text-sm text-muted-foreground mb-5 leading-relaxed\">From MVP to market-ready solutions, we engineer cutting-edge AI systems that solve critical industry challenges.</p><div class=\"flex flex-wrap gap-2\"><span class=\"text-xs px-3 py-1 rounded-full border border-border text-muted-foreground hover:border-gold/30 hover:text-foreground hover:bg-gold/5 transition-all duration-200 cursor-default\">Rapid Prototyping</span><span class=\"text-xs px-3 py-1 rounded-full border border-border text-muted-foreground hover:border-gold/30 hover:text-foreground hover:bg-gold/5 transition-all duration-200 cursor-default\">AI Integration</span><span class=\"text-xs px-3 py-1 rounded-full border border-border text-muted-foreground hover:border-gold/30 hover:text-foreground hover:bg-gold/5 transition-all duration-200 cursor-default\">Product Strategy</span></div></div></div><div class=\"transition-all duration-700 ease-out opacity-0 translate-y-8 \" style=\"transition-delay:200ms\"><div class=\"tilt-card group bg-white rounded-2xl border border-border p-6 hover:shadow-lg hover:shadow-gold/5 hover:border-gold/20 transition-all duration-300 h-full\"><div class=\"flex items-center gap-3 mb-4\"><div class=\"p-2 rounded-lg bg-muted group-hover:bg-gold/10 transition-colors duration-300\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield w-5 h-5 text-muted-foreground group-hover:text-gold transition-colors duration-300\" aria-hidden=\"true\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path></svg></div><h3 class=\"font-semibold text-foreground text-sm leading-tight\">Strategic AI Implementation</h3></div><p class=\"text-sm text-muted-foreground mb-5 leading-relaxed\">Full-stack development and AI consulting services for organizations deploying AI into mission-critical operations.</p><div class=\"flex flex-wrap gap-2\"><span class=\"text-xs px-3 py-1 rounded-full border border-border text-muted-foreground hover:border-gold/30 hover:text-foreground hover:bg-gold/5 transition-all duration-200 cursor-default\">Consulting</span><span class=\"text-xs px-3 py-1 rounded-full border border-border text-muted-foreground hover:border-gold/30 hover:text-foreground hover:bg-gold/5 transition-all duration-200 cursor-default\">Engineering</span><span class=\"text-xs px-3 py-1 rounded-full border border-border text-muted-foreground hover:border-gold/30 hover:text-foreground hover:bg-gold/5 transition-all duration-200 cursor-default\">AI Deployment</span></div></div></div><div class=\"transition-all duration-700 ease-out opacity-0 translate-y-8 \