in><section class=\"relative min-h-screen flex items-center justify-center pt-16 overflow-hidden\"><div class=\"absolute inset-0 bg-gradient-to-br from-white via-white to-muted/30\"></div><div class=\"absolute top-1/4 left-1/5 w-2 h-2 rounded-full bg-gold/30 animate-float\"></div><div class=\"absolute top-1/6 right-1/4 w-3 h-3 rounded-full bg-gold/10 animate-float\" style=\"animation-delay:1s\"></div><div class=\"absolute top-1/3 right-1/3 w-1.5 h-1.5 rounded-full bg-gold/20 animate-float\" style=\"animation-delay:2s\"></div><div class=\"absolute bottom-1/4 right-1/5 w-2.5 h-2.5 rounded-full bg-gold/15 animate-float\" style=\"animation-delay:3s\"></div><div class=\"absolute bottom-1/3 left-1/3 w-1 h-1 rounded-full bg-gold/25 animate-float\" style=\"animation-delay:4s\"></div><div class=\"absolute top-2/3 left-1/6 w-2 h-2 rounded-full bg-gold/20 animate-float\" style=\"animation-delay:5s\"></div><div class=\"relative max-w-5xl mx-auto px-6 text-center\"><h1 class=\"flex items-baseline justify-center gap-[0.3em] text-5xl md:text-7xl lg:text-8xl font-bold mb-6 tracking-tight whitespace-nowrap\"><span>Architecting</span><span class=\"inline-block w-[5.2em] text-left\"><span class=\"gold-shimmer-text inline-block transition-all duration-400 opacity-100 translate-y-0\">Intelligence</span></span></h1><p class=\"text-lg md:text-xl text-muted-foreground mb-4 max-w-2xl mx-auto animate-fade-in-up\" style=\"animation-delay:200ms\">AI-Powered Solutions Delivering<!-- --> <span class=\"gold-gradient-text font-semibold\">$2.4M+</span> in Proven Savings</p><p class=\"text-base text-muted-foreground mb-10 max-w-2xl mx-auto leading-relaxed animate-fade-in-up\" style=\"animation-delay:400ms\">We don&#x27;t just build AI chatbots—we architect full-stack software suites powered by AI, data scraping, and intelligent automation like you&#x27;ve never seen before. We&#x27;re your strategic technology partner for mission-critical systems.</p><div class=\"flex flex-col sm:flex-row gap-4 justify-center animate-fade-in-up\" style=\"animation-delay:600ms\"><a href=\"#contact\" class=\"magnetic-btn glass-btn inline-flex items-center justify-center gap-2 bg-transparent backdrop-blur-md text-foreground border border-foreground/30 px-8 py-3.5 rounded-xl text-base font-medium hover:scale-105 transition-all duration-300 group animate-pulse-glow\">Get Free Consultation<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right w-4 h-4 transition-transform group-hover:translate-x-1\" aria-hidden=\"true\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a><button class=\"magnetic-btn glass-btn inline-flex items-center justify-center gap-2 bg-transparent backdrop-blur-md text-foreground border border-foreground/20 px-8 py-3.5 rounded-xl text-base font-medium hover:scale-105 transition-all duration-300 group\">Book a Meeting<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right w-4 h-4 transition-transform group-hover:translate-x-1\" aria-hidden=\"true\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></button></div></div></section><section class=\"py-12 border-y border-border bg-muted/30 backdrop-blur-sm\"><div class=\"max-w-7xl mx-auto px-6\"><div class=\"grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8\"><div class=\"transition-all duration-700 ease-out opacity-0 scale-95 \" style=\"transition-delay:0ms\"><div class=\"text-center group transition-all duration-300 hover:scale-110 cursor-default\"><div class=\"flex justify-center mb-2 md:mb-3\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-dollar-sign h-5 w-5 md:h-6 md:w-6 text-muted-foreground group-hover:text-foreground transition-colors\" aria-hidden=\"true\"><line x1=\"12\" x2=\"12\" y1=\"2\" y2=\"22\"></line><path d=\"M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6\"></path></svg></div><div class=\"text-2xl md:text-3xl lg:text-4xl font-bold text-foreground mb-1\">$2.4M+<span class=\"text-muted-foreground text-xs md:text-base ml-0.5\">*</span></div><div class=\"text-xs md:text-sm text-muted-foreground px-1\">Client Savings</div></div></div><div class=\"transition-all duration-700 ease-out opacity-0 scale-95 \" style=\"transition-delay:150ms\"><div class=\"text-center group transition-all duration-300 hover:scale-110 cursor-default\"><div class=\"flex justify-center mb-2 md:mb-3\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-trending-up h-5 w-5 md:h-6 md:w-6 text-muted-foreground group-hover:text-foreground transition-colors\" aria-hidden=\"true\"><path d=\"M16 7h6v6\"></path><path d=\"m22 7-8.5 8.5-5-5L2 17\"></path></svg></div><div class=\"text-2xl md:text-3xl lg:text-4xl font-bold text-foreground mb-1\">180%+<span class=\"text-muted-foreground text-xs md:text-base ml-0.5\">*</span></div><div class=\"text-xs md:text-sm text-muted-foreground px-1\">Typical ROI</div></div></div><div class=\"transition-all duration-700 ease-out opacity-0 scale-95 \" style=\"transition-delay:300ms\"><div class=\"text-center group transition-all duration-300 hover:scale-110 cursor-default\"><div class=\"flex justify-center mb-2 md:mb-3\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-clock h-5 w-5 md:h-6 md:w-6 text-muted-foreground group-hover:text-foreground transition-colors\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 6v6l4 2\"></path></svg></div><div class=\"text-2xl md:text-3xl lg:text-4xl font-bold text-foreground mb-1\">2-8</div><div class=\"text-xs md:text-sm text-muted-foreground px-1\">Weeks to MVP</div></div></div><div class=\"transition-all duration-700 ease-out opacity-0 scale-95 \" style=\"transition-delay:450ms\"><div class=\"text-center group transition-all duration-300 hover:scale-110 cursor-default\"><div class=\"flex justify-center mb-2 md:mb-3\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-users h-5 w-5 md:h-6 md:w-6 text-muted-foreground group-hover:text-foreground transition-colors\" aria-hidden=\"true\"><path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"></path><path d=\"M16 3.128a4 4 0 0 1 0 7.744\"></path><path d=\"M22 21v-2a4 4 0 0 0-3-3.87\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle></svg></div><div class=\"text-2xl md:text-3xl lg:text-4xl font-bold text-foreground mb-1\">$5K+<span class=\"text-muted-foreground text-xs md:text-base ml-0.5\">*</span></div><div class=\"text-xs md:text-sm text-muted-foreground px-1\">MRR from Built Software</div></div></div></div><div class=\"mt-6 md:mt-8 text-center px-4\"><p class=\"text-[10px] md:text-xs text-muted-foreground/70 leading-relaxed\">* Internal estimates based on client reporting and project outcomes. Individual results may vary. MRR reflects recurring revenue from software we&#x27;ve commercialized after initial build.</p></div></div></section><section class=\"w-full pt-8 pb-16 bg-gradient-to-r from-white via-muted/30 to-white overflow-hidden border-y border-border/50\"><div class=\"max-w-7xl mx-auto px-6 mb-6\"><p class=\"text-center text-sm font-medium text-mu